{
  "name": "tree-mapper",
  "displayName": "Tree Mapper",
  "description": "Generate a complete Markdown snapshot of your workspace — file tree + full source code.",
  "version": "1.1.1",
  "publisher": "MrDeveloperJIS",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "tree",
    "snapshot",
    "workspace",
    "markdown",
    "documentation"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDeveloperJIS/vs_code-tree_mapper"
  },
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tree-mapper.generate",
        "title": "Tree Mapper: Generate Snapshot"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "tree-mapper.generate",
          "group": "navigation@999",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": {
      "title": "Tree Mapper",
      "properties": {
        "treemapper.additionalIgnorePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Extra glob patterns to ignore (in addition to .treeignore)."
        },
        "treemapper.maxFileSizeKB": {
          "type": "number",
          "default": 2048,
          "description": "Skip files larger than this size (in KB). Default: 2048 KB (2 MB)."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint src",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  },
  "license": "MIT"
}